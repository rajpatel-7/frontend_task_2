@model List<frontend_task_2.Models.Report>
@{
    ViewData["Title"] = "My Reports";
}

<div class="mt-4 mb-4 d-flex justify-content-between align-items-center">
    <h3>My Medical Reports</h3>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<div class="row">
    @foreach (var report in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100 border-start border-4 border-info">



                <div class="card-header bg-white">
           <strong>Report #@report.Id</strong>
                </div>
                <div class="card-body">
                    <h5 class="text-primary mb-3">@report.Diagnosis</h5>




                    <p class="mb-1"><strong><i class="bi bi-file-medical"></i> Tests Recommended:</strong></p>
              <p class="text-muted">@report.TestRecommended</p>



                    

                    <p class="mb-1 mt-3"><strong><i class="bi bi-journal-text"></i> Doctor's Remarks:</strong></p>
           <p class="text-muted">@report.Remarks</p>



                </div>
            </div>
        </div>
    }
    
    @if(!Model.Any())
    {
        <div class="col-12 mt-3 text-center text-muted">
            <p>You have no reports</p>
        </div>
    }
</div>
