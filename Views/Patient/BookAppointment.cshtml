@model frontend_task_2.Models.BookAppointmentRequest
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">


        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white text-center py-3">


                <h4 class="mb-0">New Appointment</h4>
            </div>
            <div class="card-body p-4">


                
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger shadow-sm">


                        @ViewBag.Error
                    </div>
                }

                <form asp-action="BookAppointment" method="post">
                  

                    <div class="mb-4">
                        <label asp-for="AppointmentDate" class="form-label fw-bold">Appointment Date</label>




                        <input asp-for="AppointmentDate" type="date" class="form-control form-control-lg" required />
                    </div>

               

                    <div class="mb-4">
                        <label asp-for="TimeSlot" class="form-label fw-bold">Time Slot</label>
                        <select asp-for="TimeSlot" class="form-select form-select-lg" required>
                            <option value="">Select Time Slot</option>
                            <option value="09:00-09:15">09:00 AM - 09:15 AM</option>
                            <option value="09:15-09:30">09:15 AM - 09:30 AM</option>
                            <option value="09:30-09:45">09:30 AM - 09:45 AM</option>
                            <option value="10:00-10:15">10:00 AM - 10:15 AM</option>
                            <option value="10:30-10:45">10:30 AM - 10:45 AM</option>
                            <option value="11:00-11:15">11:00 AM - 11:15 AM</option>
                            <option value="11:30-11:45">11:30 AM - 11:45 AM</option>
                            <option value="12:00-12:15">12:00 PM - 12:15 PM</option>
                        </select>
                        <small class="text-muted mt-1 d-block">Please choose an available 15-minute slot.</small>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-light btn-lg border">Cancel</a>


                        <button type="submit" class="btn btn-primary btn-lg px-5">Book Now</button>
                    </div>


                </form>
            </div>


        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
